{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["firefox-webext-browser", "vitest/globals"],
    "noImplicitAny": false,
    "noImplicitThis": true,
    "strictNullChecks": false
  },
  "include": [
    "background/**/*.js",
    "content/**/*.js",
    "sidebar/**/*.js",
    "options/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "web-ext-artifacts"
  ]
}
